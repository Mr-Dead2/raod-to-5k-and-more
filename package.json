{
  "name": "road-to-5k",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "npm run build && wrangler dev",
    "icons": "node scripts/gen-icons.mjs",
    "deploy": "npm run build && wrangler deploy",
    "android:assets": "node scripts/gen-app-assets.mjs && npx @capacitor/assets generate --android",
    "android:sync": "npm run build && npx cap sync android",
    "android:open": "npx cap open android",
    "android:apk": "npm run build && npx cap sync android && cd android && ./gradlew assembleDebug"
  },
  "dependencies": {
    "@capacitor-community/background-geolocation": "^1.2.26",
    "@capacitor/app": "^6.0.3",
    "@capacitor/core": "^6.2.1",
    "@capacitor/filesystem": "^6.0.4",
    "@capacitor/geolocation": "^6.1.1",
    "@capacitor/haptics": "^6.0.3",
    "@capacitor/local-notifications": "^6.1.3",
    "@capacitor/share": "^6.0.4",
    "@capacitor/status-bar": "^6.0.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.2.1",
    "@cloudflare/vite-plugin": "^1.40.0",
    "@vitejs/plugin-react": "^4.3.4",
    "sharp": "^0.33.5",
    "vite": "^6.0.7",
    "vite-plugin-pwa": "^0.21.1",
    "wrangler": "^4.98.0"
  }
}
